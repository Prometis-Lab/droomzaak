{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "NotebookEdit",
      "Agent",
      "Task",
      "TaskCreate",
      "TaskUpdate",
      "TaskGet",
      "TaskList",
      "Skill",
      "WebFetch",
      "WebSearch",
      "mcp__*",
      "Bash"
    ],
    "deny": [
      "Bash(git push)",
      "Bash(git push:*)",
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(doas:*)",
      "Read(.env)",
      "Read(./.env)",
      "Read(**/.env)",
      "Read(.env.local)",
      "Read(**/.env.local)",
      "Read(.env.demo)",
      "Read(**/.env.demo)",
      "Read(**/.env.*.local)",
      "Read(**/secrets/**)"
    ],
    "ask": []
  },

  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r 'if (.tool_input.command | test(\"^git commit\")) then {\"hookSpecificOutput\":{\"hookEventName\":\"PostToolUse\",\"additionalContext\":\"A commit just landed. If this finished a meaningful chunk, drop a short handover via the writing-handovers skill into docs/handovers/<track>/<YYYY-MM-DD-HHMM>-<author>-<slug>.md so a teammate or fresh session can resume cleanly. Skip for trivial/doc-only commits.\"}} else {} end' 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
