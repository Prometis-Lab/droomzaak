# Droomzaak — demo secrets template
# Copy to `.env.demo` (gitignored) and fill in. NEVER commit the filled file.
# These power BOTH the product runtime AND the dev-time MCP/tools.
# Pre-provision everything here on Friday night (PRD §3.7).

# ── DataGateway (the agent's analytical read path) ─────────────────────
# The product reaches the droomzaak Postgres through ONE internal DataGateway
# running parameterized SQL (asyncpg/psycopg). This is the single audited seam.
DROOMZAAK_PG_DSN=                                # the droomzaak Postgres DSN (= SUPABASE_DB_URL); the DataGateway's connection

# ── Supabase (hosts the droomzaak Postgres; dev/deploy tooling, NOT the agent's read path) ──
# Read-only Supabase MCP + local schema mirror under supabase/. See the supabase-schema-sync skill.
SUPABASE_PROJECT_REF=                            # your project ref (e.g. abcdefghijklmnop)
SUPABASE_ACCESS_TOKEN=                           # personal access token for the read-only MCP — never commit
SUPABASE_DB_URL=postgresql://postgres:pass@db.<ref>.supabase.co:5432/postgres   # for psql / pg_dump / failover

# ── Model providers (both wired so we can swap mid-demo, PRD §6.1) ─────
AGENT_PROVIDER=anthropic                          # anthropic | openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AGENT_LANGUAGE=nl                                 # nl primary, en fallback

# ── Live tools (behaviour, NOT routed through the DataGateway) ─────────
GOOGLE_MAPS_API_KEY=                              # Places (New) search + Street View Static; billing ON
VITE_GOOGLE_MAPS_API_KEY=                         # Same key re-exposed for Vite (frontend Street View Static image in MarkerStreetView)
OPENROUTESERVICE_API_KEY=                         # isochrones
TAVILY_API_KEY=                                   # web_search fallback (official-domain biased)

# ── Optional data-prep tokens (Friday curation) ───────────────────────
TELRAAM_API_KEY=                                  # optional footfall calibration (X-Api-Key); composite degrades without it

# ── Dev-time MCP aids (optional) ──────────────────────────────────────
CONTEXT7_API_KEY=                                 # context7 live-docs MCP (optional; works without for many libs)
